# ─── Stratum Gateway Configuration ───

# Server
PORT=8000
# LOG_LEVEL:
# - debug: access logs + stream lifecycle debug logs
# - info: clean terminal output (banner + warnings/errors + one inference_done per chat request)
LOG_LEVEL=info

# Authentication
API_KEY=change-me

# AWS Credentials
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Features
ENABLE_METRICS=false

# Optional explicit model policy path.
# If empty, Stratum resolves config/model-policy.yaml from executable dir, then cwd.
MODEL_POLICY_PATH=

# Gateway safeguards
MAX_REQUEST_BODY_BYTES=10485760
