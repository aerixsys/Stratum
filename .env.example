# ─── Stratum Gateway Configuration ───

# Server
PORT=8000
LOG_LEVEL=info

# Authentication
API_KEY=sk-bedrock-gateway-1234

# AWS Credentials
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# CORS (comma-separated origins, or * for all)
ALLOWED_ORIGINS=*

# Features
ENABLE_CROSS_REGION_INFERENCE=true
ENABLE_APP_INFERENCE_PROFILES=false
ENABLE_PROMPT_CACHING=true
ENABLE_METRICS=false

# Gateway safeguards
MAX_REQUEST_BODY_BYTES=10485760
RATE_LIMIT_RPM=120
RATE_LIMIT_BURST=20

# Default model (fallback when not specified)
DEFAULT_MODEL=amazon.nova-micro-v1:0

# Multimodal image fetch hardening
ALLOW_PRIVATE_IMAGE_FETCH=false
IMAGE_MAX_BYTES=5242880
IMAGE_FETCH_TIMEOUT_SECONDS=10
